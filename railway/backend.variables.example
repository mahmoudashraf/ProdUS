SPRING_PROFILES_ACTIVE=prod
PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
SPRING_DATASOURCE_USERNAME=${{Postgres.PGUSER}}
SPRING_DATASOURCE_PASSWORD=${{Postgres.PGPASSWORD}}
SUPABASE_URL=
SUPABASE_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_CORS_ALLOWED_ORIGINS=https://${{produs-frontend.RAILWAY_PUBLIC_DOMAIN}}
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_REQUESTS_PER_MINUTE=300
APP_PAYMENT_WEBHOOK_SECRET=
APP_SIGNATURE_WEBHOOK_SECRET=
AWS_S3_ENDPOINT=https://s3.amazonaws.com
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_PRESIGNED_URL_DURATION=3600
LOOMAI_ENABLED=false
LOOMAI_BASE_URL=
LOOMAI_API_KEY=
LOOMAI_TIMEOUT_MS=2500
