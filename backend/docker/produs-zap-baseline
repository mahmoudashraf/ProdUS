#!/usr/bin/env bash
set -uo pipefail

zap_home=""
for ((i = 1; i <= $#; i++)); do
    if [[ "${!i}" == "-z" ]]; then
        next=$((i + 1))
        if (( next <= $# )); then
            zap_opts="${!next}"
            if [[ "$zap_opts" =~ (^|[[:space:]])-dir[[:space:]]+([^[:space:]]+) ]]; then
                zap_home="${BASH_REMATCH[2]}"
            fi
        fi
    fi
done

cleanup_zap() {
    if [[ -z "$zap_home" ]]; then
        return
    fi
    pkill -TERM -f "/zap/zap-x\\.sh.*-dir ${zap_home}" 2>/dev/null || true
    pkill -TERM -f "/opt/zap/zap-[^ ]*\\.jar.*-dir ${zap_home}" 2>/dev/null || true
    sleep 1
    pkill -KILL -f "/zap/zap-x\\.sh.*-dir ${zap_home}" 2>/dev/null || true
    pkill -KILL -f "/opt/zap/zap-[^ ]*\\.jar.*-dir ${zap_home}" 2>/dev/null || true
}

trap cleanup_zap EXIT INT TERM
export JAVA_TOOL_OPTIONS="${PRODUS_ZAP_JAVA_TOOL_OPTIONS:--Xmx768m -Djava.security.egd=file:/dev/./urandom}"

/usr/local/bin/zap-baseline.py "$@"
status=$?
cleanup_zap
exit "$status"
