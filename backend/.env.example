# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5433/easyluxury
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key


# S3 for prod using dev MinIO
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=easyluxury
AWS_ACCESS_KEY=minioadmin
AWS_SECRET_KEY=minioadmin


# MinIO Configuration for AI Profiles
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=easyluxury
MINIO_PRESIGNED_EXPIRY=7

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT=60

# OpenAI Rate Limiting
OPENAI_RATE_LIMIT_REQUESTS_PER_MINUTE=60
OPENAI_RATE_LIMIT_REQUESTS_PER_HOUR=1000


# Server Configuration
SERVER_PORT=8080
REQUIRE_SSL=true

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://easyluxury.com,https://www.easyluxury.com

# Swagger/API Documentation
SWAGGER_ENABLED=false

# Logging Configuration
LOG_FILE_PATH=/var/log/easyluxury/backend.log

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

APP_MOCK_AUTH_ENABLED=true