{
  "name": "@produs/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Model Context Protocol gateway for the ProdUS backend API",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
